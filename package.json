{
  "name": "nebula",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "lucide-react": "^1.7.0",
    "postcss": "^8.5.8",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.2.2",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.3.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "effector": "^23.4.4",
    "effector-react": "^23.3.0"
  }
}
